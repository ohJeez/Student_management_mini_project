# =============================================
#  EduPortal – Railway environment variables
#  Copy this to Railway → Variables tab
# =============================================

# REQUIRED – generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Your Railway domain e.g. eduportal.up.railway.app
ALLOWED_HOSTS=yourdomain.up.railway.app,localhost

# Railway auto-injects this when you add a PostgreSQL plugin – do NOT set manually
# DATABASE_URL=postgresql://...
